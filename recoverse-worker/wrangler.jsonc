{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "recoverse-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-06",
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "815a411838d34921b97a391fa7d78632"
    }
  ],
  // 프로덕션: 빌드된 프론트를 같은 오리진에서 서빙 (API는 /api/*, 나머지는 SPA)
  "assets": {
    "directory": "../recoverse-frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
